graph LR
    subgraph I1["Intervención 1\nToken-Level Loss"]
        I1A["GRPO: pérdida ÷ longitud\nde cada respuesta"]
        I1B["DAPO: pérdida ÷ total\nde tokens del grupo"]
        I1A -->|"Elimina length bias\nen el gradiente"| I1B
    end

    subgraph I2["Intervención 2\nOverlong Reward Shaping"]
        I2A["Respuesta supera L_cache"]
        I2B["Penalización progresiva\n= (long − L_cache) / (L_max − L_cache)"]
        I2A --> I2B
    end

    subgraph I3["Intervención 3\nClip-Higher Asimétrico"]
        I3A["PPO: clip(ratio, 0.8, 1.2)\nSimétrico ±0.2"]
        I3B["DAPO: clip(ratio, 0.8, 1.5)\nMás margen para subir"]
        I3A -->|"Tokens prometedores\npueden emerger"| I3B
    end

    subgraph I4["Intervención 4\nDynamic Sampling"]
        I4A["Grupo muestreado"]
        I4B{¿Al menos 1 correcta\ny 1 incorrecta?}
        I4C["Usar grupo\npara actualización"]
        I4D["Descartar y\nre-muestrear"]
        I4A --> I4B
        I4B -->|Sí| I4C
        I4B -->|No| I4D
        I4D --> I4A
    end

    classDef viejo fill:#ffcccc,stroke:#cc0000,color:#000
    classDef nuevo fill:#ccffcc,stroke:#006600,color:#000
    classDef proceso fill:#cce5ff,stroke:#0066cc,color:#000
    classDef decision fill:#fff3cd,stroke:#856404,color:#000

    class I1A,I3A viejo
    class I1B,I3B nuevo
    class I2A,I2B,I4A,I4C,I4D proceso
    class I4B decision
