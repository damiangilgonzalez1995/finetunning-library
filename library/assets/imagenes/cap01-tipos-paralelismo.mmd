graph LR
    subgraph DDP["Data Parallelism (DDP)"]
        direction TB
        D1["GPU 0:<br/>Modelo completo<br/>+ Batch A"]
        D2["GPU 1:<br/>Modelo completo<br/>+ Batch B"]
        D1 <-->|"AllReduce<br/>gradientes"| D2
    end

    subgraph TP["Tensor Parallelism (TP)"]
        direction TB
        T1["GPU 0:<br/>Mitad de la<br/>matriz de pesos"]
        T2["GPU 1:<br/>Otra mitad de la<br/>matriz de pesos"]
        T1 <-->|"AllGather<br/>(requiere NVLink)"| T2
    end

    subgraph PP["Pipeline Parallelism (PP)"]
        direction TB
        P1["GPU 0:<br/>Capas 1-10"]
        P2["GPU 1:<br/>Capas 11-20"]
        P1 -->|"Activaciones"| P2
    end

    subgraph SP["Sequence Parallelism (SP)"]
        direction TB
        S1["GPU 0:<br/>Tokens 1-64k"]
        S2["GPU 1:<br/>Tokens 64k-128k"]
        S1 <-->|"Sincronización<br/>atención"| S2
    end

    classDef gpuA fill:#4A90D9,stroke:#2C5F8A,color:#fff
    classDef gpuB fill:#50B86C,stroke:#2D7A42,color:#fff

    class D1,T1,P1,S1 gpuA
    class D2,T2,P2,S2 gpuB
