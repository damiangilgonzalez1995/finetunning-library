graph TD
    subgraph GRPO_IS["GRPO — Ratio token a token"]
        T1["ratio_t1 = π_nueva(t1) / π_vieja(t1)"]
        T2["ratio_t2 = π_nueva(t2) / π_vieja(t2)"]
        T3["ratio_t500 = π_nueva(t500) / π_vieja(t500)"]
